[Unit]
Description=Podman Prometheus Exporter
After=observability-pod.service podman.socket
Requires=observability-pod.service podman.socket

[Container]
Image=quay.io/navidys/prometheus-podman-exporter:latest
Pod=observability.pod
ContainerName=podman-exporter
Environment=CONTAINER_HOST=unix:///run/podman/podman.sock
Volume=/run/user/1000/podman/podman.sock:/run/podman/podman.sock:ro
UserNS=keep-id:uid=65534
SecurityLabelDisable=true

[Service]
Restart=always

[Install]
WantedBy=default.target